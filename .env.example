# Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gravecare

# Flask
SECRET_KEY=your-secret-key-here-change-in-production
ENVIRONMENT=development

# Frontend
FRONTEND_BASE_URL=http://localhost:5173

# Registration
REGISTRATION_ENABLED=true

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/google-calendar/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=your-encryption-key-here

# Email Configuration (SMTP)
# Pro Gmail: 
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=your-email@gmail.com
#   MAIL_PASSWORD=your-app-password (ne běžné heslo!)
#
# Pro ostatní poskytovatele (e.g. Hetzner):
#   MAIL_SERVER=smtp.your-provider.com
#   MAIL_PORT=587 nebo 465
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=your-email@domain.com
#   MAIL_PASSWORD=your-smtp-password
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@gravecare.local
